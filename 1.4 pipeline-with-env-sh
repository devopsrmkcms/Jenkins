pipeline {
    agent any

    environment {
        APP_NAME = "Entrust"
        APP_VERSION = "v1.3"
        USER_NAME = "admin"
    }

    stages {
        stage("Build_Test_Deploy") {
            steps {
                echo "Application Name: ${APP_NAME}"
                echo "Application Version: ${APP_VERSION}"
                echo "User Name: ${USER_NAME}"

                sh 'date'
                sh 'uptime'
                sh 'df -hT'
                sh 'free -g'
            }
        }
    }
  }
